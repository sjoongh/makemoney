# research_data/ is committed as a versioned dataset snapshot (daily OHLCV).
# Only transient/garbage artifacts are ignored:
research_data/_quarantine/
research_data/*.backup
research_data/*.tmp
experiments/

# OMC advisor scratch artifacts (Codex/Gemini consult outputs)
.omc/artifacts/

# Forward recorder output — point-in-time raw bars + membership log, grows
# daily via cron (machine-local; snapshot to git periodically like research_data).
forward_data/
research_data/_universe_log.jsonl

# EDGAR fundamentals store (point-in-time, fetched — re-fetchable, not committed)
fundamentals_edgar/

# Beta/defensive paper forward track (grows daily via cron)
beta_paper_track.jsonl

# S&P500 list cache (machine-regenerated resilience cache)
research_data/_sp500_cache.json
